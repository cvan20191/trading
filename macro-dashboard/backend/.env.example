# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...

# To use OpenRouter instead of OpenAI directly:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=minimax/minimax-m2.7   (or any OpenRouter model slug)
# OPENAI_USE_JSON_SCHEMA=false        # set False for OpenRouter — skips failed json_schema attempt, ~2x faster

# Optional overrides (defaults shown)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.2
# OPENAI_TIMEOUT=30
# CORS_ORIGINS=["http://localhost:5173"]

# --------------------------------------------------------------------------
# Live Data Ingestion (Stage 3)
# --------------------------------------------------------------------------

# FRED API key — REQUIRED. Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_key_here
# Cache TTL in seconds (default 900 = 15 minutes)
# LIVE_CACHE_TTL_SECONDS=900

# Serve stale cached snapshot when providers fail (default true)
# LIVE_ALLOW_STALE_CACHE=true

# HTTP request timeout for provider calls in seconds (default 20)
# HTTP_TIMEOUT_SECONDS=20

# --------------------------------------------------------------------------
# Policy support heuristics
# These are used when live political/fiscal signals cannot be sourced via API.
# The fed_put is also auto-inferred from a falling rate trend.
# --------------------------------------------------------------------------
# DEFAULT_FED_PUT=false
# DEFAULT_TREASURY_PUT=false
# DEFAULT_POLITICAL_PUT=false

# --------------------------------------------------------------------------
# Valuation Provider — Financial Modeling Prep (FMP)
# --------------------------------------------------------------------------

# FMP API key — used for Mag 7 Forward P/E basket computation
# Get a free key at: https://financialmodelingprep.com/developer/docs
# FMP_API_KEY=your_key_here

# Valuation provider: "fmp" (default, uses FMP Mag 7 basket) | "yahoo" (forces Yahoo QQQ proxy fallback)
# VALUATION_PROVIDER=fmp

# --------------------------------------------------------------------------
# PMI manual override
# ISM PMI data is not available from free public APIs.
# Set these to inject the latest values manually after each monthly release.
# --------------------------------------------------------------------------
# PMI_MANUFACTURING=49.0
# PMI_SERVICES=51.0
